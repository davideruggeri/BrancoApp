{
  "cli": {
    "version": ">= 16.20.0",
    "appVersionSource": "remote"
  },
  "build": {
    "development": {
      "developmentClient": true,
      "distribution": "internal"
    },
    "preview": {
      "distribution": "internal"
    },
    "production": {
      "autoIncrement": true
    },
    "web": {
      "production": {
        "buildCommand": "expo export:web",
        "outputDir": "web-build"
      }
    }
  },
  "submit": {
    "production": {}
  }
}
